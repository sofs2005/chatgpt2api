# ============================================
# ChatGPT2API 环境变量配置示例
# ============================================

# 认证密钥（必填）
CHATGPT2API_AUTH_KEY=your_secret_key_here

# 基础 URL（可选，用于生成图片 URL）
# CHATGPT2API_BASE_URL=https://your-domain.com

# 全局代理（可选，支持 http/https/socks5/socks5h）
# CHATGPT2API_PROXY=http://127.0.0.1:7890

# 限流账号检查间隔，单位：分钟
CHATGPT2API_REFRESH_ACCOUNT_INTERVAL_MINUTE=5

# 同时生成图片张数限制
CHATGPT2API_IMAGE_CONCURRENT_LIMIT=4

# 普通用户默认同时处理图片张数限制，0 表示不限制
CHATGPT2API_USER_DEFAULT_CONCURRENT_LIMIT=0

# 普通用户默认图片任务 RPM 限制，0 表示不限制
CHATGPT2API_USER_DEFAULT_RPM_LIMIT=0

# 服务端缓存图片保留天数
CHATGPT2API_IMAGE_RETENTION_DAYS=30

# 自动移除失效账号
CHATGPT2API_AUTO_REMOVE_INVALID_ACCOUNTS=true

# 自动移除限流账号
CHATGPT2API_AUTO_REMOVE_RATE_LIMITED_ACCOUNTS=false

# 记录日志级别，多个值用英文逗号分隔：debug,info,warning,error
# CHATGPT2API_LOG_LEVELS=warning,error

# ============================================
# Linuxdo 登录配置（可选）
# ============================================

# 启用 Linuxdo Connect 登录
# CHATGPT2API_LINUXDO_ENABLED=false

# Linuxdo Connect 应用凭据
# CHATGPT2API_LINUXDO_CLIENT_ID=
# CHATGPT2API_LINUXDO_CLIENT_SECRET=

# 后端 OAuth 回调地址；Linuxdo Connect 应用后台也必须填写这个后端地址。
# 如未设置且 CHATGPT2API_BASE_URL 已设置，会默认使用：
# ${CHATGPT2API_BASE_URL}/auth/linuxdo/oauth/callback
# CHATGPT2API_LINUXDO_REDIRECT_URL=https://your-domain.com/auth/linuxdo/oauth/callback

# 前端接收本地会话密钥的路由；不要填到 Linuxdo Connect 应用后台。
# CHATGPT2API_LINUXDO_FRONTEND_REDIRECT_URL=/auth/linuxdo/callback

# Linuxdo Connect 端点，通常无需修改
# CHATGPT2API_LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
# CHATGPT2API_LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
# CHATGPT2API_LINUXDO_USERINFO_URL=https://connect.linux.do/api/user
# CHATGPT2API_LINUXDO_SCOPES=user

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认: json
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt2api

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（不指定时自动使用 data/accounts.db）
# DATABASE_URL=sqlite:///app/data/accounts.db

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git 访问令牌（必填）
# GitHub: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认: accounts.json）
# GIT_FILE_PATH=accounts.json
